# Proxy Host
PROXY_HOST=127.0.0.1

# Proxy Port
PROXY_PORT=8000

# Anthropic-compatible DeepSeek base URL. /v1/messages is appended by the proxy.
UPSTREAM_BASE_URL=https://api.deepseek.com/anthropic

# SQLite database path for stored assistant content blocks and tool call indexes.
DB_PATH=./deepseek_anthropic_proxy.sqlite3

# Upstream HTTP timeout in seconds for non-stream and streaming requests.
REQUEST_TIMEOUT_SECONDS=120

# Enable request repair: inject/replace missing assistant thinking blocks before tool_result turns.
ENABLE_THINKING_REPAIR=true

# If true, unknown tool_result.tool_use_id returns local 400. If false, forwards unchanged.
REPAIR_STRICT=false

# If true, writes full request/response JSON under LOG_DIR. Console still shows 20-char previews.
LOG_FULL_REQUEST=false

# Directory for full JSON exchange logs when LOG_FULL_REQUEST=true.
LOG_DIR=./log

# If true, stores every assistant content[] response. If false, stores only responses with tool_use.
STORE_ALL_ASSISTANT_CONTENT=true
